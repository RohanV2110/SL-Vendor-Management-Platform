generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  PARTNER
}

enum PartnerApplicationStatus {
  SUBMITTED
  UNDER_REVIEW
  REJECTED
  APPROVED_PENDING_DOCUMENTS
  DOCUMENTS_SENT
  SIGNED_DOCUMENTS_UPLOADED
  ACTIVE
  INACTIVE
}

enum PartnerAccountStatus {
  INVITED
  PENDING_DOCUMENTS
  PENDING_ACTIVATION
  ACTIVE
  INACTIVE
}

enum ReferralStatus {
  SUBMITTED
  DUPLICATE_NOT_ATTRIBUTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  CONVERTED
  LOST
  CLAWED_BACK
}

enum DealStage {
  NEW
  QUALIFYING
  PROPOSAL
  NEGOTIATION
  CLOSED_WON
  CLOSED_LOST
}

enum PartnerDealStatus {
  PENDING_APPROVAL
  APPROVED
  REJECTED
}

enum PartnerDealStage {
  PROCESSING
  WON
  LOST
}

enum CommissionType {
  PERCENTAGE
  FIXED
}

enum CommissionLedgerStatus {
  PENDING_APPROVAL
  APPROVED
  SCHEDULED
  PAYABLE
  PAID
  CLAWED_BACK
  VOID
}

enum CommissionEntryType {
  UPFRONT
  TRAILING
  CLAWBACK
  ADJUSTMENT
}

enum AgreementStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  INACTIVE
}

enum AgreementDocumentType {
  NDA
  PARTNER_AGREEMENT
}

enum AgreementDocumentStatus {
  REQUESTED
  UPLOADED
  VERIFIED
  REJECTED
}

enum PayoutBatchStatus {
  DRAFT
  READY
  SUBMITTED
  PAID
  FAILED
}

enum QuarterlyActivityStatus {
  MET_THRESHOLD
  BELOW_THRESHOLD
  OVERRIDDEN
}

enum NoteEntityType {
  APPLICATION
  PARTNER
  REFERRAL
  DEAL
}

model User {
  id                String          @id @default(cuid())
  email             String          @unique
  passwordHash      String
  name              String
  role              UserRole
  isActive          Boolean         @default(true)
  partnerAccountId  String?         @unique
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  partnerAccount    PartnerAccount? @relation(fields: [partnerAccountId], references: [id])
  reviewedApplications PartnerApplication[] @relation("ApplicationReviewer")
  reviewedReferrals Referral[]      @relation("ReferralReviewer")
  verifiedDocuments AgreementDocument[] @relation("DocumentVerifier")
  verifiedCommissionEntries CommissionLedgerEntry[] @relation("CommissionVerifier")
  internalNotes     InternalNote[]
  auditLogs         AuditLog[]
  notifications     Notification[]
}

model Product {
  id          String      @id @default(cuid())
  name        String
  slug        String      @unique
  description String?
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  packages    Package[]
  tierRules   TierRule[]
  prompts     QuestionPrompt[]
  applications PartnerApplication[]
  referrals   Referral[]
  deals       Deal[]
  agreements  Agreement[]
}

model Package {
  id          String    @id @default(cuid())
  productId   String
  name        String
  slug        String
  description String?
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  product     Product   @relation(fields: [productId], references: [id], onDelete: Cascade)
  tierRules   TierRule[]
  referrals   Referral[]
  deals       Deal[]
  agreements  Agreement[]

  @@unique([productId, slug])
}

model Tier {
  id          String                   @id @default(cuid())
  name        String
  slug        String                   @unique
  description String?
  isDefault   Boolean                  @default(false)
  isActive    Boolean                  @default(true)
  createdAt   DateTime                 @default(now())
  updatedAt   DateTime                 @updatedAt
  rules       TierRule[]
  applications PartnerApplication[]
  partners    PartnerAccount[]
  agreements  Agreement[]
  snapshots   QuarterlyActivitySnapshot[]
}

model TierRule {
  id                            String         @id @default(cuid())
  tierId                        String
  productId                     String?
  packageId                     String?
  upfrontCommissionType         CommissionType
  upfrontCommissionValue        Decimal        @db.Decimal(10, 2)
  trailingCommissionType        CommissionType?
  trailingCommissionValue       Decimal?       @db.Decimal(10, 2)
  trailingDurationMonths        Int?
  trailingCadenceMonths         Int?
  clawbackWindowDays            Int?
  quarterlyApprovedReferralsMin Int?
  quarterlyConvertedDealsMin    Int?
  quarterlyRevenueMin           Decimal?       @db.Decimal(12, 2)
  quarterlyCommissionMin        Decimal?       @db.Decimal(12, 2)
  isActive                      Boolean        @default(true)
  createdAt                     DateTime       @default(now())
  updatedAt                     DateTime       @updatedAt
  tier                          Tier           @relation(fields: [tierId], references: [id], onDelete: Cascade)
  product                       Product?       @relation(fields: [productId], references: [id])
  package                       Package?       @relation(fields: [packageId], references: [id])
}

model QuestionPrompt {
  id          String      @id @default(cuid())
  productId   String?
  label       String
  helperText  String?
  promptType  String      @default("textarea")
  isRequired  Boolean     @default(true)
  sortOrder   Int         @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  product     Product?    @relation(fields: [productId], references: [id])
  answers     ApplicationAnswer[]
}

model PartnerApplication {
  id                    String                   @id @default(cuid())
  fullName              String
  email                 String
  phone                 String
  company               String
  country               String
  city                  String                   @default("")
  promotionChannels     String
  aiTechExperience      String
  audienceDescription   String
  status                PartnerApplicationStatus @default(SUBMITTED)
  adminNotes            String?
  submittedAt           DateTime                 @default(now())
  reviewedAt            DateTime?
  activatedAt           DateTime?
  productId             String?
  assignedTierId        String?
  referredByVendorId    String?
  referralCodeUsed      String?
  reviewedById          String?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt
  product               Product?                 @relation(fields: [productId], references: [id])
  assignedTier          Tier?                    @relation(fields: [assignedTierId], references: [id])
  referredByVendor      PartnerAccount?          @relation("VendorReferredApplications", fields: [referredByVendorId], references: [id], onDelete: SetNull)
  reviewedBy            User?                    @relation("ApplicationReviewer", fields: [reviewedById], references: [id])
  partnerAccount        PartnerAccount?
  answers               ApplicationAnswer[]
  notes                 InternalNote[]

  @@index([email])
  @@index([status])
  @@index([referredByVendorId])
  @@index([referralCodeUsed])
}

model ApplicationAnswer {
  id               String             @id @default(cuid())
  applicationId    String
  questionPromptId String
  promptSnapshot   String
  response         String
  createdAt        DateTime           @default(now())
  application      PartnerApplication @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  questionPrompt   QuestionPrompt     @relation(fields: [questionPromptId], references: [id])
}

model PartnerAccount {
  id                        String                   @id @default(cuid())
  applicationId             String                   @unique
  tierId                    String
  affiliateId               String?                  @unique
  vendorReferralCode        String?                  @unique
  vendorReferralCodeActive  Boolean                  @default(false)
  vendorReferralCodeGeneratedAt DateTime?
  referralClicks            Int                      @default(0)
  referredByVendorId        String?
  referralCodeUsed          String?
  company                   String
  primaryContactName        String
  primaryContactEmail       String                   @unique
  phone                     String
  country                   String
  city                      String                   @default("")
  status                    PartnerAccountStatus     @default(INVITED)
  stripeAccountId           String?
  stripeOnboardingComplete  Boolean                  @default(false)
  activatedAt               DateTime?
  activationNoticeSeenAt    DateTime?
  ndaSignedAt               DateTime?
  ndaMarkedById             String?
  agreementSignedAt         DateTime?
  agreementMarkedById       String?
  createdAt                 DateTime                 @default(now())
  updatedAt                 DateTime                 @updatedAt
  application               PartnerApplication       @relation(fields: [applicationId], references: [id])
  tier                      Tier                     @relation(fields: [tierId], references: [id])
  referredByVendor          PartnerAccount?          @relation("VendorAffiliates", fields: [referredByVendorId], references: [id], onDelete: SetNull)
  affiliates                PartnerAccount[]         @relation("VendorAffiliates")
  referredApplications      PartnerApplication[]      @relation("VendorReferredApplications")
  profile                   PartnerProfile?
  agreements                Agreement[]
  user                      User?
  inviteTokens              PartnerInvite[]
  referrals                 Referral[]
  deals                     Deal[]
  partnerDeals              PartnerDeal[]
  commissions               CommissionLedgerEntry[]
  snapshots                 QuarterlyActivitySnapshot[]
  payoutBatches             PayoutBatch[]
  notifications             Notification[]
  documents                 AgreementDocument[]
  notes                     InternalNote[]

  @@index([referredByVendorId])
  @@index([referralCodeUsed])
}

model PartnerProfile {
  id                   String         @id @default(cuid())
  partnerAccountId     String         @unique
  promotionChannels    String
  aiTechExperience     String
  audienceDescription  String
  companyWebsite       String?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  partnerAccount       PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
}

model PartnerInvite {
  id               String         @id @default(cuid())
  partnerAccountId String
  email            String
  token            String         @unique
  expiresAt        DateTime
  usedAt           DateTime?
  createdAt        DateTime       @default(now())
  partnerAccount   PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
}

model Agreement {
  id                            String                 @id @default(cuid())
  partnerAccountId              String
  tierId                        String
  productId                     String?
  packageId                     String?
  name                          String
  version                       Int                    @default(1)
  status                        AgreementStatus        @default(DRAFT)
  effectiveStartDate            DateTime
  effectiveEndDate              DateTime?
  upfrontCommissionType         CommissionType?
  upfrontCommissionValue        Decimal?               @db.Decimal(10, 2)
  trailingCommissionType        CommissionType?
  trailingCommissionValue       Decimal?               @db.Decimal(10, 2)
  trailingDurationMonths        Int?
  trailingCadenceMonths         Int?
  clawbackWindowDays            Int?
  quarterlyApprovedReferralsMin Int?
  quarterlyConvertedDealsMin    Int?
  quarterlyRevenueMin           Decimal?               @db.Decimal(12, 2)
  quarterlyCommissionMin        Decimal?               @db.Decimal(12, 2)
  createdAt                     DateTime               @default(now())
  updatedAt                     DateTime               @updatedAt
  partnerAccount                PartnerAccount         @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  tier                          Tier                   @relation(fields: [tierId], references: [id])
  product                       Product?               @relation(fields: [productId], references: [id])
  package                       Package?               @relation(fields: [packageId], references: [id])
  documents                     AgreementDocument[]
  commissionEntries             CommissionLedgerEntry[]

  @@index([partnerAccountId, status])
}

model AgreementDocument {
  id               String                  @id @default(cuid())
  partnerAccountId String
  agreementId      String?
  type             AgreementDocumentType
  status           AgreementDocumentStatus @default(REQUESTED)
  fileName         String?
  fileUrl          String?
  requestedAt      DateTime                @default(now())
  uploadedAt       DateTime?
  verifiedAt       DateTime?
  verifiedById     String?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt
  partnerAccount   PartnerAccount          @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  agreement        Agreement?              @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  verifiedBy       User?                   @relation("DocumentVerifier", fields: [verifiedById], references: [id])

  @@unique([partnerAccountId, type])
}

model Referral {
  id                   String         @id @default(cuid())
  partnerAccountId     String
  productId            String
  packageId            String?
  referredCompany      String
  referredContactName  String
  referredContactEmail String?
  referredDomain       String?
  normalizedLeadKey    String
  sourceNotes          String
  useCaseSummary       String
  estimatedDealValue   Decimal?       @db.Decimal(12, 2)
  attachmentName       String?
  attachmentUrl        String?
  status               ReferralStatus @default(SUBMITTED)
  isAttributed         Boolean        @default(false)
  reviewReason         String?
  adminNotes           String?
  reviewedById         String?
  submittedAt          DateTime       @default(now())
  approvedAt           DateTime?
  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt
  partnerAccount       PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  product              Product        @relation(fields: [productId], references: [id])
  package              Package?       @relation(fields: [packageId], references: [id])
  reviewedBy           User?          @relation("ReferralReviewer", fields: [reviewedById], references: [id])
  deal                 Deal?
  commissionEntries    CommissionLedgerEntry[]
  notes                InternalNote[]

  @@index([normalizedLeadKey])
  @@index([status])
  @@index([partnerAccountId, submittedAt])
}

model Deal {
  id               String         @id @default(cuid())
  referralId       String         @unique
  partnerAccountId String
  productId        String
  packageId        String?
  stage            DealStage      @default(NEW)
  ownerName        String
  expectedValue    Decimal?       @db.Decimal(12, 2)
  closedValue      Decimal?       @db.Decimal(12, 2)
  closeDate        DateTime?
  summaryNotes     String?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  referral         Referral       @relation(fields: [referralId], references: [id], onDelete: Cascade)
  partnerAccount   PartnerAccount @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  product          Product        @relation(fields: [productId], references: [id])
  package          Package?       @relation(fields: [packageId], references: [id])
  commissionEntries CommissionLedgerEntry[]
  notes            InternalNote[]

  @@index([stage])
}

model PartnerDeal {
  id                String            @id @default(cuid())
  partnerAccountId  String
  name              String
  email             String
  companyName       String
  website           String?
  phoneCountryCode  String?
  phoneNumber       String?
  country           String
  state             String
  notes             String?
  dealValue         Decimal?          @db.Decimal(12, 2)
  status            PartnerDealStatus @default(PENDING_APPROVAL)
  stage             PartnerDealStage  @default(PROCESSING)
  trailingStoppedAt DateTime?
  reviewedAt        DateTime?
  reviewedById      String?
  rejectionReason   String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt
  partnerAccount    PartnerAccount    @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  commissionEntries CommissionLedgerEntry[]

  @@index([partnerAccountId])
  @@index([status])
  @@index([stage])
  @@index([email])
}

model CommissionLedgerEntry {
  id                  String                 @id @default(cuid())
  partnerAccountId    String
  referralId          String?
  dealId              String?
  partnerDealId       String?
  agreementId         String
  payoutBatchId       String?
  parentEntryId       String?
  type                CommissionEntryType
  status              CommissionLedgerStatus @default(PENDING_APPROVAL)
  amount              Decimal                @db.Decimal(12, 2)
  currency            String                 @default("USD")
  percentageApplied   Decimal?               @db.Decimal(10, 2)
  scheduledFor        DateTime?
  payableAt           DateTime?
  paidAt              DateTime?
  trailingVerifiedAt  DateTime?
  trailingVerifiedById String?
  stripePayoutId      String?
  description         String
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt
  partnerAccount      PartnerAccount         @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  referral            Referral?              @relation(fields: [referralId], references: [id], onDelete: SetNull)
  deal                Deal?                  @relation(fields: [dealId], references: [id], onDelete: SetNull)
  partnerDeal         PartnerDeal?           @relation(fields: [partnerDealId], references: [id], onDelete: SetNull)
  agreement           Agreement              @relation(fields: [agreementId], references: [id])
  payoutBatch         PayoutBatch?           @relation(fields: [payoutBatchId], references: [id], onDelete: SetNull)
  parentEntry         CommissionLedgerEntry? @relation("ClawbackParent", fields: [parentEntryId], references: [id], onDelete: SetNull)
  clawbackEntries     CommissionLedgerEntry[] @relation("ClawbackParent")
  trailingVerifiedBy  User?                  @relation("CommissionVerifier", fields: [trailingVerifiedById], references: [id], onDelete: SetNull)

  @@index([partnerAccountId, status])
  @@index([partnerDealId, type])
}

model QuarterlyActivitySnapshot {
  id                   String                  @id @default(cuid())
  partnerAccountId     String
  tierId               String
  year                 Int
  quarter              Int
  approvedReferrals    Int                     @default(0)
  convertedDeals       Int                     @default(0)
  revenueAmount        Decimal                 @default(0) @db.Decimal(12, 2)
  commissionAmount     Decimal                 @default(0) @db.Decimal(12, 2)
  status               QuarterlyActivityStatus
  overrideNote         String?
  computedAt           DateTime                @default(now())
  partnerAccount       PartnerAccount          @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  tier                 Tier                    @relation(fields: [tierId], references: [id])

  @@unique([partnerAccountId, year, quarter])
}

model PayoutBatch {
  id               String            @id @default(cuid())
  partnerAccountId String
  label            String
  status           PayoutBatchStatus @default(DRAFT)
  scheduledAt      DateTime?
  submittedAt      DateTime?
  paidAt           DateTime?
  stripePayoutId   String?
  notes            String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  partnerAccount   PartnerAccount    @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  commissionEntries CommissionLedgerEntry[]
}

model Notification {
  id               String         @id @default(cuid())
  partnerAccountId String?
  userId           String?
  title            String
  body             String
  href             String?
  readAt           DateTime?
  createdAt        DateTime       @default(now())
  partnerAccount   PartnerAccount? @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  user             User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id           String   @id @default(cuid())
  actorUserId  String?
  entityType   String
  entityId     String
  action       String
  summary      String
  previousState Json?
  nextState    Json?
  createdAt    DateTime @default(now())
  actorUser    User?    @relation(fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
}

model InternalNote {
  id               String         @id @default(cuid())
  entityType       NoteEntityType
  entityId         String
  partnerAccountId String?
  applicationId    String?
  referralId       String?
  dealId           String?
  body             String
  authorId         String
  createdAt        DateTime       @default(now())
  author           User           @relation(fields: [authorId], references: [id])
  partnerAccount   PartnerAccount? @relation(fields: [partnerAccountId], references: [id], onDelete: Cascade)
  application      PartnerApplication? @relation(fields: [applicationId], references: [id], onDelete: Cascade)
  referral         Referral?      @relation(fields: [referralId], references: [id], onDelete: Cascade)
  deal             Deal?          @relation(fields: [dealId], references: [id], onDelete: Cascade)
}
